# ── Database ─────────────────────────────────────────────────────────────────
# SQLite — a single file, no server needed.
# On Railway (or any host with an ephemeral filesystem): this MUST point inside
# a mounted persistent Volume, e.g. "file:/data/pecko.db" with the volume mounted
# at /data. Without a volume, every deploy wipes the database back to seed data.
DATABASE_URL="file:./pecko.db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ── Anthropic (NOT required) ──────────────────────────────────────────────────
# BOM extraction is now deterministic (per-customer Excel column mapping), so no
# API key is needed. Left here for a future optional AI-assisted mode.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Set to true ONLY if your server is behind HTTPS/TLS (e.g., nginx with SSL).
# Leave false for plain HTTP on a local/internal network.
HTTPS=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to the URL users access the app on.
# If Express serves both frontend + backend (default), use the server's own URL.
# Example for LAN:  http://192.168.1.50:3001
# Example for dev:  http://localhost:5173
CLIENT_URL=http://localhost:3001

# ── File storage ──────────────────────────────────────────────────────────────
# Same rule as DATABASE_URL above: on Railway this must be inside the mounted
# Volume, e.g. UPLOAD_DIR=/data/uploads — otherwise converted files vanish on deploy.
UPLOAD_DIR=./uploads
LOG_LEVEL=info

# ── RFQ sync ──────────────────────────────────────────────────────────────────
# Shared secret the Power Automate flow sends as the "x-rfq-secret" header to POST /api/rfq/sync.
RFQ_SYNC_SECRET=change-me-to-a-long-random-string

# ── RFQ nightly Graph sync (Path B) ───────────────────────────────────────────
# App-only Microsoft Graph creds so the server pulls the RFQ master file at 10pm SGT.
# From an Azure AD (Entra) app registration with Files.Read.All application permission (admin-consented).
# Leave unset to disable the scheduler (manual "Sync Now" upload still works).
RFQ_GRAPH_TENANT_ID=
RFQ_GRAPH_CLIENT_ID=
RFQ_GRAPH_CLIENT_SECRET=
# Optional overrides — default to the known PENDING PROJECT file:
# RFQ_GRAPH_DRIVE_ID=
# RFQ_GRAPH_ITEM_ID=

# ── TrustedParts.com Inventory API (Source Raw Materials) ─────────────────────
# Credentials for the electronics part sourcing search (TrustedParts Inventory API v2).
# CompanyId is your assigned account name; the API key is in your TrustedParts portal.
TRUSTEDPARTS_COMPANY_ID=
TRUSTEDPARTS_API_KEY=

# ── Ask AI part-sourcing chat (Source Raw Materials > Search) ──────────────────
# DeepSeek powers the conversational assistant; Tavily grounds it in real web
# search results so it finds real independent stockists (never hallucinated).
# Both are needed for the "Ask AI" tab. Create as Railway Variables in prod.
DEEPSEEK_API_KEY=
TAVILY_API_KEY=
