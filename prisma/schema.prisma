generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite does not support native enums.
// Role values: "ADMIN" | "USER"
// Company values: "PEI" | "PM" | "PKS" (null = all/none)
// ConversionStatus values: "SUCCESS" | "FAILED"
// Enforced by Zod at the API layer.

model User {
  id           String   @id @default(cuid())
  username     String
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  company      String?  // PEI | PM | PKS (null = all/none)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversionLogs ConversionLog[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  // JSON: which spreadsheet columns map to which BOM fields (fixed per customer).
  // null → the standard layout (see DEFAULT_MAPPING in services/bomExtractor.js).
  columnMapping String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uomMappings    UnitOfMeasureMapping[]
  conversionLogs ConversionLog[]
}

model UnitOfMeasureMapping {
  id               String   @id @default(cuid())
  customerId       String
  customerUOM      String
  peckoUOM         String
  conversionFactor Float    @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, customerUOM])
}

model ManufacturerMapping {
  id                   String   @id @default(cuid())
  customerManufacturer String   @unique
  peckoManufacturer    String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ProductRegistry {
  id         String @id @default(cuid())
  itemName   String @unique
  externalId String
}

model ConversionLog {
  id                String   @id @default(cuid())
  userId            String?
  customerId        String?
  originalFilename  String
  status            String
  productsConverted Int      @default(0)
  bomsConverted     Int      @default(0)
  createdAt         DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

// RFQ dashboard: a full snapshot of the "PENDING PROJECT" master sheet, replaced wholesale on each
// sync (the Excel file is the source of truth; diffing ~900 rows isn't worth it).
// status: COMPLETED | PENDING_REVIEW | OTHER | NONE  (derived from the row's fill color)
model RfqProject {
  id                 String    @id @default(cuid())
  rowNumber          Int
  projectId          String
  customer           String    @default("")
  linkSource         String    @default("")
  pic                String    @default("")
  projectType        String    @default("")
  notes              String    @default("")
  rfqDueDateRaw      String    @default("")
  rfqDueDate         DateTime?
  rfqReceivedDateRaw String    @default("")
  sofeaDateRaw       String    @default("")
  submissionDateRaw  String    @default("")
  status             String
  syncedAt           DateTime  @default(now())

  @@index([status])
}

model RfqSync {
  id            String   @id @default(cuid())
  syncedAt      DateTime @default(now())
  source        String   // 'upload' | 'webhook'
  total         Int      @default(0)
  completed     Int      @default(0)
  pendingReview Int      @default(0)
  other         Int      @default(0)
  none          Int      @default(0)
}
